{
  "name": "phaser-games",
  "private": true,
  "type": "module",
  "workspaces": [
    "games/*"
  ],
  "scripts": {
    "//": "Per-game scripts are added by the phaser-new-game skill, e.g. dev:snake / build:snake / preview:snake (preview serves the prod build for the smoke-test).",
    "build:all": "node scripts/build-all.mjs",
    "typecheck": "tsc -b --pretty games/*",
    "dev:flappy-bird": "vite --config games/flappy-bird/vite.config.mjs games/flappy-bird",
    "build:flappy-bird": "vite build --config games/flappy-bird/vite.config.mjs games/flappy-bird",
    "preview:flappy-bird": "vite preview --config games/flappy-bird/vite.config.mjs games/flappy-bird",
    "dev:gold-miner": "vite --config games/gold-miner/vite.config.mjs games/gold-miner",
    "build:gold-miner": "vite build --config games/gold-miner/vite.config.mjs games/gold-miner",
    "preview:gold-miner": "vite preview --config games/gold-miner/vite.config.mjs games/gold-miner",
    "dev:survivor": "vite --config games/survivor/vite.config.mjs games/survivor",
    "build:survivor": "vite build --config games/survivor/vite.config.mjs games/survivor",
    "preview:survivor": "vite preview --config games/survivor/vite.config.mjs games/survivor",
    "dev:frog-crossing": "vite --config games/frog-crossing/vite.config.mjs games/frog-crossing",
    "build:frog-crossing": "vite build --config games/frog-crossing/vite.config.mjs games/frog-crossing",
    "preview:frog-crossing": "vite preview --config games/frog-crossing/vite.config.mjs games/frog-crossing"
  },
  "devDependencies": {
    "phaser": "^4.1.0",
    "terser": "^5.31.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
